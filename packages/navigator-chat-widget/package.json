{
  "name": "@foggy/navigator-chat-widget",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/navigator-chat-widget.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/navigator-chat-widget.js"
    },
    "./style.css": "./dist/navigator-chat-widget.css"
  },
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "vite build --watch",
    "dev:observe": "vite --host 0.0.0.0 --port 5179 --strictPort",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test --grep @live --workers=1",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "element-plus": "^2.13.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "element-plus": "^2.13.1",
    "happy-dom": "^20.6.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.24",
    "vue-tsc": "^3.1.4"
  },
  "dependencies": {
    "@foggy/chat": "workspace:*",
    "markdown-it": "^14.1.0"
  }
}
