spring:
  application:
    name: foggy-navigator

  datasource:
    url: jdbc:mysql://localhost:13309/coding_agent?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
    username: foggy
    password: 'foggy@123'
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQLDialect
        format_sql: true

navigator:
  langgraph:
    worker:
      # Set when multiple LangGraph BizWorkers are registered in one Navigator instance.
      default-worker-id: ${NAVIGATOR_LANGGRAPH_WORKER_DEFAULT_WORKER_ID:}

# 日志配置
logging:
  level:
    root: INFO
    com.foggy.navigator: DEBUG
    com.github.dockerjava: WARN
