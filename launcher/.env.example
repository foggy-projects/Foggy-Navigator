# 系统初始化配置
# 将此文件复制为 .env 并填写实际值
# 所有变量均有默认值，仅需覆盖需要修改的项

# ── Java 路径 ──────────────────────────────────────
# 指定 Java 可执行文件路径（默认使用系统 PATH 中的 java）
# JAVA_PATH=C:\Program Files\Java\jdk-17\bin\java.exe

# ── ROOT 账号 ──────────────────────────────────────
ROOT_USERNAME=root
ROOT_PASSWORD=root123
ROOT_EMAIL=root@foggy.local

# 密码强制重置开关（仅在需要重置密码时取消注释，重置完成后务必删除此行）
# ROOT_PASSWORD_RESET=true

# ── 应用配置 ──────────────────────────────────────
APP_PORT=8112
SPRING_PROFILES_ACTIVE=docker

# ── 安全配置（生产环境必须修改） ──────────────────
# JWT 签名密钥
# JWT_SECRET=your-production-jwt-secret-key

# 凭证加密密钥（用于加密存储的 API Key 等敏感信息）
# NAVIGATOR_CREDENTIAL_KEY=your-production-credential-key
# NAVIGATOR_CREDENTIAL_SALT=your-16-char-hex-salt

# ── Navigator 平台地址 ────────────────────────────
# 对外可达的后端地址，注入到 Claude Code SKILL.md 模板中
# 单机部署无需修改；Worker 与 Launcher 分离部署时需设置为 Launcher 的可达地址
# NAVIGATOR_API_EXTERNAL_URL=http://localhost:8112