# dev-kvm-x3 Navigator platform bootstrap template.
# Copy to /opt/foggy/navigator/runtime/platform-bootstrap.env on dev-kvm-x3.
# Keep the real file chmod 0600 and do not commit secrets.

NAVIGATOR_API_BASE=http://127.0.0.1:8112
NAVIGATOR_PUBLIC_BASE_URL=http://192.168.31.81:8112

NAVIGATOR_ROOT_USERNAME=root
NAVIGATOR_ROOT_PASSWORD=

NAVIGATOR_TENANT_ID=tms-x3
NAVIGATOR_TENANT_ADMIN_USERNAME=tms-admin
NAVIGATOR_TENANT_ADMIN_PASSWORD=
NAVIGATOR_TENANT_ADMIN_EMAIL=tms-admin@tms-x3.local
NAVIGATOR_TENANT_ADMIN_DISPLAY_NAME='TMS X3 Admin'

NAVIGATOR_LLM_NAME=tms-x3-qwen3.5-plus
NAVIGATOR_LLM_BASE_URL=http://test.synthoflow.com:3061/v1
NAVIGATOR_LLM_MODEL=qwen3.5-plus
NAVIGATOR_LLM_API_KEY=

NAVIGATOR_BIZ_WORKER_ID=dev-kvm-x3-langgraph-biz-worker
NAVIGATOR_BIZ_WORKER_NAME='dev-kvm-x3 LangGraph Biz Worker'
NAVIGATOR_BIZ_WORKER_BASE_URL=http://192.168.31.81:3061
NAVIGATOR_BIZ_WORKER_TOKEN=
NAVIGATOR_BIZ_WORKER_POOL_ID=tms-x3-langgraph-pool
NAVIGATOR_BIZ_WORKER_POOL_NAME='TMS X3 LangGraph Worker Pool'

NAVIGATOR_TMS_CLIENT_APP_NAME='TMS X3 Demo'
NAVIGATOR_TMS_CLIENT_APP_DESCRIPTION='TMS X3 dev/demo integration for Navigator Business Agent.'
NAVIGATOR_TMS_CAPABILITY_DOMAIN=TMS
NAVIGATOR_TMS_WEB_BASE_URL=http://192.168.31.81:12580
NAVIGATOR_TMS_AGENT_CODE=tms.navigator.agent
NAVIGATOR_TMS_SKILL_ID=tms.navigator.agent
NAVIGATOR_TMS_AGENT_NAME='TMS Navigator Agent'
NAVIGATOR_TMS_AGENT_DESCRIPTION='Navigator Business Agent for TMS X3 dev/demo.'
NAVIGATOR_TMS_SEED_UPSTREAM_USER_ID=tms-x3-smoke-user
NAVIGATOR_TMS_SEED_UPSTREAM_USER_TOKEN=
NAVIGATOR_TMS_MATERIALIZE_AGENT_BUNDLE=false
NAVIGATOR_PLATFORM_SMOKE_TASK=false

# Leave unset to run LangGraph Biz Worker from the release source for IMAGE_TAG.
# Set only for emergency compatibility with a manually managed source tree.
# BIZ_WORKER_SOURCE_DIR=/opt/foggy/navigator/current/tools/langgraph-biz-worker
BIZ_WORKER_PORT=3061
BIZ_WORKER_HOST=0.0.0.0
BIZ_WORKER_LLM_EXECUTE_SKILLS=true
BIZ_WORKER_LLM_SKILL_MAX_ITERATIONS=6
