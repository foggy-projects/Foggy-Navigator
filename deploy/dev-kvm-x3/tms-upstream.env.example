# TMS -> Foggy Navigator x3 integration template.
# Copy to a gitignored local/server env file before use.
# The real dev/demo values with secrets are on dev-kvm-x3:
#   /opt/foggy/navigator/runtime/tms-upstream.env

NAVI_BASE_URL=http://192.168.31.81:8112
NAVI_TENANT_ID=tms-x3

NAVI_CLIENT_APP_ID=capp_91859c0b-9049-46fa-ba2b-a4fcce50e3c9
NAVI_CLIENT_APP_KEY=<read-from-x3-runtime-env>
NAVI_CLIENT_APP_SECRET=<read-from-x3-runtime-env>
NAVI_CLIENT_APP_ACCESS_TOKEN=

# Server-side bootstrap/manifest sync only. Never expose to browser or commit.
NAVI_CONTROL_API_KEY=<read-from-x3-runtime-env>

# Smoke user only. Real TMS users should be granted lazily by the TMS BFF.
NAVI_UPSTREAM_USER_ID=tms-x3-smoke-user
NAVI_UPSTREAM_USER_TOKEN=<read-from-x3-runtime-env>

NAVI_AGENT_CODE=tms.navigator.agent
NAVI_SKILL_ID=tms.navigator.agent
NAVI_MODEL_CONFIG_ID=de146b42-23db-4b2b-b349-0af76aa61ad3
NAVI_WORKER_POOL_ID=tms-x3-langgraph-pool
NAVI_POLL_INTERVAL_SECONDS=4

TMS_WEB_BASE_URL=http://192.168.31.81:12580

# Employee local shell only. Do not commit real API keys.
OPENAI_BASE_URL=http://test.synthoflow.com:3061/v1
OPENAI_API_KEY=<employee-local-secret>
OPENAI_MODEL=qwen3.5-plus
