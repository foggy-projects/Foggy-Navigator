# Navigator image release settings.
# Copy to runtime/release.env on the target host. Do not commit the filled file.

# Git source used only on build-and-push nodes such as dev-kvm-x3.
GIT_URL=
GIT_REF=main
IMAGE_TAG=dev-kvm-x3-YYYYMMDD-N

# Registry
HARBOR_REGISTRY=test.synthoflow.com:8080
HARBOR_PROJECT=x3
HARBOR_USERNAME=
HARBOR_PASSWORD=

# Build inputs
NPM_REGISTRY='http://192.168.31.81:4873'
MAVEN_ARGS=-DskipTests
PNPM_INSTALL_ARGS=--no-frozen-lockfile

# Runtime image names. Keep the component names aligned with Harbor.
NAVIGATOR_BACKEND_IMAGE="test.synthoflow.com:8080/x3/navigator-backend:${IMAGE_TAG}"
NAVIGATOR_FRONTEND_IMAGE="test.synthoflow.com:8080/x3/navigator-frontend:${IMAGE_TAG}"

# Runtime mode
SPRING_PROFILES_ACTIVE=dev-kvm-x3
TZ=Asia/Shanghai
NAVIGATOR_LOCAL_INFRA=true
NAVIGATOR_STOP_LEGACY_SOURCE=true
NAVIGATOR_DEPLOY_HEALTH_RETRIES=45
NAVIGATOR_DEPLOY_HEALTH_INTERVAL_SECONDS=2

# Workers are node runtimes installed from OBS, not part of the Navigator app images.
WORKER_INSTALL_CLAUDE=true
WORKER_INSTALL_CODEX=false
WORKER_INSTALL_GEMINI=false
CLAUDE_WORKER_URL='https://obs-fe55.obs.cn-north-4.myhuaweicloud.com/claude-worker'
CODEX_WORKER_URL='https://obs-fe55.obs.cn-north-4.myhuaweicloud.com/codex-worker'
GEMINI_WORKER_URL='https://obs-fe55.obs.cn-north-4.myhuaweicloud.com/gemini-worker'
CLAUDE_WORKER_HEALTH_URL='http://127.0.0.1:3031/health'
CODEX_WORKER_HEALTH_URL='http://127.0.0.1:3051/health'
GEMINI_WORKER_HEALTH_URL='http://127.0.0.1:3071/health'

# Public endpoints
NAVIGATOR_FRONTEND_URL='http://192.168.31.81'
NAVIGATOR_API_EXTERNAL_URL='http://192.168.31.81:8112'
NAVIGATOR_BACKEND_HEALTH_URL='http://127.0.0.1:8112/actuator/health'
NAVIGATOR_FRONTEND_HEALTH_URL='http://127.0.0.1/health'
NAVIGATOR_WORKER_HEALTH_URL='http://127.0.0.1:3031/health'

# Database. For local infra, use foggy-navigator-mysql:3306 inside compose.
SPRING_DATASOURCE_URL='jdbc:mysql://foggy-navigator-mysql:3306/coding_agent?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true'
SPRING_DATASOURCE_USERNAME=foggy
SPRING_DATASOURCE_PASSWORD=
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=coding_agent
MYSQL_USER=foggy
MYSQL_PASSWORD=

# RabbitMQ. Required when monitoring/event bus is enabled.
RABBITMQ_HOST=foggy-navigator-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=foggy
RABBITMQ_PASS=

# Application secrets. Generate environment-specific values before production.
JWT_SECRET=
SYSTEM_ROOT_USERNAME=root
SYSTEM_ROOT_PASSWORD=
SYSTEM_ROOT_EMAIL=root@foggy.local
NAVIGATOR_CREDENTIAL_KEY=
NAVIGATOR_CREDENTIAL_SALT=

# TMS upstream adapter, if enabled.
TMS_X3_AGENT_UPSTREAM_URL=
TMS_X3_AGENT_USER_TOKEN_HEADER=X-TMS-Agent-Token

# Business Agent materialize worker. Keep token values in server-only runtime env.
BUSINESS_AGENT_DEV_SYNC_WORKER_URL='http://192.168.31.81:3061'
BUSINESS_AGENT_DEV_SYNC_WORKER_TOKEN=

# Worker runtime env is managed in ~/.claude-worker/.env, ~/.codex-worker/.env
# and ~/.gemini-worker/.env after OBS installation.
