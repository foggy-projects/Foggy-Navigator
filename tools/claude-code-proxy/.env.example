# ============================================================
# Single-Key Mode (backward compatible)
# ============================================================
# If no OPENAI_API_KEY_<NAME> vars exist, this key is used for all requests.
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Optional: Expected Anthropic API key for client validation (single-key mode only)
# If set, clients must provide this exact API key to access the proxy
ANTHROPIC_API_KEY="your-expected-anthropic-api-key"

# Optional: OpenAI API base URL (default: https://api.openai.com/v1)
OPENAI_BASE_URL="https://api.openai.com/v1"

# Optional: Model mappings (global defaults, also used as fallback for per-key)
BIG_MODEL="gpt-4o"          # Claude opus  -> this model
MIDDLE_MODEL="gpt-4o"       # Claude sonnet -> this model
SMALL_MODEL="gpt-4o-mini"   # Claude haiku  -> this model

# ============================================================
# Multi-Key Pool Mode
# ============================================================
# Define multiple backend keys with OPENAI_API_KEY_<NAME>.
# Each key can optionally have its own base URL and model mappings.
# If per-key settings are omitted, the global defaults above are used.

# --- Backend A (e.g. GLM / Zhipu) ---
# OPENAI_API_KEY_A=glm-key-xxx
# OPENAI_BASE_URL_A=https://open.bigmodel.cn/api/paas/v4
# BIG_MODEL_A=glm-4.7
# MIDDLE_MODEL_A=glm-4.7
# SMALL_MODEL_A=glm-4.5-air

# --- Backend B (e.g. Aliyun DashScope Anthropic-compatible) ---
# OPENAI_API_KEY_B=sk-ali-key-xxx
# OPENAI_BASE_URL_B=https://coding.dashscope.aliyuncs.com/apps/anthropic
# PASSTHROUGH_B=true
# (When passthrough=true, model mappings are ignored — requests are forwarded as-is)

# --- Backend C (e.g. Aliyun / Qwen OpenAI-compatible) ---
# OPENAI_API_KEY_C=sk-ali-key-xxx
# OPENAI_BASE_URL_C=https://dashscope.aliyuncs.com/compatible-mode/v1
# BIG_MODEL_C=qwen-max
# MIDDLE_MODEL_C=qwen-max
# SMALL_MODEL_C=qwen-turbo

# --- Client Key Mapping (optional) ---
# Maps client API keys to specific backend key pools.
# Format: client_key:backend1,backend2;client_key2:backend3
# If not set, all backend keys are available to all clients (round-robin).
# KEY_MAPPING=sk-ant-a1:A,B;sk-ant-a2:B;sk-ant-a3:A,B

# ============================================================
# Server & Performance Settings
# ============================================================
HOST="0.0.0.0"
PORT="8082"
LOG_LEVEL="INFO"             # DEBUG, INFO, WARNING, ERROR, CRITICAL
MAX_TOKENS_LIMIT="4096"
MIN_TOKENS_LIMIT="4096"      # Minimum tokens (avoids errors with thinking models)
REQUEST_TIMEOUT="90"
MAX_RETRIES="2"

# ============================================================
# Provider-Specific Examples
# ============================================================

# Azure OpenAI:
# OPENAI_API_KEY="your-azure-api-key"
# OPENAI_BASE_URL="https://your-resource.openai.azure.com/openai/deployments/your-deployment"
# AZURE_API_VERSION="2024-03-01-preview"
# BIG_MODEL="gpt-4"
# MIDDLE_MODEL="gpt-4"
# SMALL_MODEL="gpt-35-turbo"

# Local models (Ollama):
# OPENAI_API_KEY="dummy-key"
# OPENAI_BASE_URL="http://localhost:11434/v1"
# BIG_MODEL="llama3.1:70b"
# MIDDLE_MODEL="llama3.1:70b"
# SMALL_MODEL="llama3.1:8b"

# ============================================================
# Custom Headers
# ============================================================
# Format: CUSTOM_HEADER_<NAME>=value (underscores become hyphens)
# CUSTOM_HEADER_ACCEPT="application/jsonstream"
# CUSTOM_HEADER_X_API_KEY="your-api-key"
# CUSTOM_HEADER_X_CLIENT_ID="your-client-id"

# ============================================================
# Release Configuration (Developer Only)
# ============================================================
# Used by dist/upload.ps1 and dist/upload.sh for OBS deployment.
# Not needed for normal proxy operation.
# RELEASE_OBS_BUCKET=obs://your-bucket/claude-code-proxy
# RELEASE_BASE_URL=https://your-bucket.obs.cn-north-4.myhuaweicloud.com/claude-code-proxy
