# ============================================================
# LLM Gateway (One API) 配置
# 复制为 .env 后修改
# ============================================================

# 网关监听端口
GATEWAY_PORT=3000

# 初始 Root Token（可选，首次启动时自动创建 root 用户）
# 留空则使用默认密码 123456，建议首次登录后立即修改
INITIAL_ROOT_TOKEN=

# 会话密钥（生产环境务必修改为随机字符串）
SESSION_SECRET=foggy-llm-gateway-secret

# 全局 API 频率限制（每分钟请求数，0=不限制）
GLOBAL_API_RATE_LIMIT=180

# 日志保留天数
LOG_MAX_DAYS=30
