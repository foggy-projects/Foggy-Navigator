BIZ_WORKER_PORT=3061
BIZ_WORKER_HOST=0.0.0.0
BIZ_WORKER_WORKER_NAME=biz-worker-dev
BIZ_WORKER_WORKER_TOKEN=
BIZ_WORKER_MAX_CONCURRENT_TASKS=5

# LLM execution (leave LLM_PROVIDER empty to use rule-based fallback)
BIZ_WORKER_LLM_PROVIDER=
BIZ_WORKER_LLM_API_KEY=
BIZ_WORKER_LLM_BASE_URL=
BIZ_WORKER_LLM_MODEL=
BIZ_WORKER_LLM_TEMPERATURE=0.0
BIZ_WORKER_LLM_EXECUTE_SKILLS=false
BIZ_WORKER_LLM_SKILL_MAX_ITERATIONS=20
BIZ_WORKER_ENABLE_COMMAND=true

# Public Skill sync from GitLab (leave SKILL_GIT_REPO empty to disable)
BIZ_WORKER_SKILL_GIT_REPO=
BIZ_WORKER_SKILL_GIT_BRANCH=main
BIZ_WORKER_SKILL_GIT_TOKEN=
BIZ_WORKER_SKILL_SYNC_ON_STARTUP=true
BIZ_WORKER_SKILL_WEBHOOK_SECRET=
