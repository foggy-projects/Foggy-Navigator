# Codex Agent Worker Configuration
CODEX_WORKER_PORT=3051
CODEX_WORKER_HOST=0.0.0.0
CODEX_WORKER_NAME=codex-worker-default

# OpenAI API Key (default, can be overridden per-request)
OPENAI_API_KEY=sk-xxx

# OpenAI Base URL (default, can be overridden per-request)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Bearer token for authentication (optional)
CODEX_WORKER_TOKEN=

# Allowed working directories (comma-separated, empty = allow all)
CODEX_ALLOWED_CWDS=

# Maximum concurrent tasks
CODEX_MAX_CONCURRENT_TASKS=6

# Log level: debug, info, warn, error
CODEX_LOG_LEVEL=info

# Auto-upgrade URL (set automatically by remote installer, or manually)
# `codex-worker upgrade` checks latest.json at this URL for new versions
# CODEX_WORKER_URL=https://your-bucket.obs.cn-north-4.myhuaweicloud.com/codex-worker

# ---- Release config (developer only, not needed on target machines) ----
# OBS bucket path for obsutil upload
# RELEASE_OBS_BUCKET=obs://your-bucket/codex-worker
# Public HTTP download URL
# RELEASE_BASE_URL=https://your-bucket.obs.cn-north-4.myhuaweicloud.com/codex-worker
