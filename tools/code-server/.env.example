# Code Server Configuration
# Copy this file to .env and modify as needed.

# Port for code-server web UI
CODE_SERVER_PORT=8443

# Mode: windows (npm global, native) | wsl (standalone binary in WSL)
CODE_SERVER_MODE=windows

# Project directory to open (Windows path for windows mode)
CODE_SERVER_PROJECT=D:\foggy-projects\Foggy-Navigator

# ---- WSL mode only ----
# CODE_SERVER_INSTALL=/mnt/d/foggy-tools/code-server
# CODE_SERVER_DATA=/mnt/d/foggy-tools/code-server-data
