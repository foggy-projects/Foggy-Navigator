# Claude Agent Worker — Release Configuration
# Copy this file to release.env and fill in your values.
# This file is used by package/upload scripts on the developer machine only.

# 华为云 OBS Bucket 路径（obsutil 格式）
RELEASE_OBS_BUCKET=obs://your-bucket/claude-worker

# 对应的公网 HTTP 下载地址（目标机器用此 URL 下载）
RELEASE_BASE_URL=https://your-bucket.obs.cn-east-3.myhuaweicloud.com/claude-worker

# obsutil 必须已安装并配置好 AK/SK
# 安装: https://support.huaweicloud.com/utiltg-obs/obs_11_0003.html
# 配置: obsutil config -i=AK -k=SK -e=obs.cn-east-3.myhuaweicloud.com
