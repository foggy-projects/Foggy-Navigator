#!/bin/bash
# claude-worker -- Unified CLI for Claude Agent Worker
# Supports: start | stop | status | version | logs | upgrade | help
set -e

INSTALL_DIR="${CLAUDE_WORKER_HOME:-$HOME/.claude-worker}"

# Allow running from monorepo (dist/bin/claude-worker → worker root is ../..)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$SCRIPT_DIR/../../src/agent_worker/__init__.py" ] && [ ! -f "$INSTALL_DIR/VERSION" ]; then
    INSTALL_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
fi

VERSION=$(cat "$INSTALL_DIR/VERSION" 2>/dev/null || echo "unknown")
PORT=3031

# Load port from .env
if [ -f "$INSTALL_DIR/.env" ]; then
    _port=$(grep "^AGENT_WORKER_PORT=" "$INSTALL_DIR/.env" 2>/dev/null | cut -d= -f2)
    [ -n "$_port" ] && PORT="$_port"
fi

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; GRAY='\033[0;37m'; NC='\033[0m'

cmd_start() {
    echo -e "${CYAN}Starting Claude Agent Worker v${VERSION}...${NC}"
    if [[ "$(uname)" == "Darwin" ]]; then
        bash "$INSTALL_DIR/start-mac.sh"
    else
        bash "$INSTALL_DIR/start.sh"
    fi
}

cmd_stop() {
    bash "$INSTALL_DIR/stop.sh"
}

cmd_status() {
    echo -e "${CYAN}Claude Agent Worker${NC}"
    echo -e "  Version:  ${GREEN}${VERSION}${NC}"
    echo -e "  Install:  $INSTALL_DIR"
    echo -e "  Port:     $PORT"

    # Check if process is running
    PIDS=$(lsof -ti:$PORT 2>/dev/null || true)
    if [ -n "$PIDS" ]; then
        echo -e "  Status:   ${GREEN}RUNNING${NC} (PID: $PIDS)"
        # Try health check
        HEALTH=$(curl -s --max-time 3 "http://localhost:$PORT/health" 2>/dev/null || echo "")
        if [ -n "$HEALTH" ]; then
            echo -e "  Health:   $HEALTH"
        fi
    else
        echo -e "  Status:   ${GRAY}STOPPED${NC}"
    fi
}

cmd_version() {
    echo "claude-worker $VERSION"
}

cmd_logs() {
    LOG_FILE="$INSTALL_DIR/logs/worker.log"
    if [ -f "$LOG_FILE" ]; then
        tail -f "$LOG_FILE"
    else
        echo -e "${YELLOW}No log file found at $LOG_FILE${NC}"
        echo -e "${YELLOW}The worker may not have been started yet.${NC}"
    fi
}

cmd_upgrade() {
    CURRENT_VERSION="$VERSION"

    echo -e "${CYAN}Claude Agent Worker Upgrade${NC}"

    # Check if local archive path provided
    if [ -n "$1" ] && [ -f "$1" ]; then
        echo -e "${CYAN}Upgrading from local archive: $1${NC}"
        _upgrade_from_archive "$1"
        return
    fi

    # Load CLAUDE_WORKER_URL from .env if not already set
    if [ -z "$CLAUDE_WORKER_URL" ] && [ -f "$INSTALL_DIR/.env" ]; then
        CLAUDE_WORKER_URL=$(grep "^CLAUDE_WORKER_URL=" "$INSTALL_DIR/.env" 2>/dev/null | cut -d= -f2)
    fi

    # --- Priority 1: OBS / custom URL (CLAUDE_WORKER_URL) ---
    if [ -n "$CLAUDE_WORKER_URL" ]; then
        _upgrade_from_obs "$CLAUDE_WORKER_URL"
        return
    fi

    # --- Priority 2: GitHub Releases (CLAUDE_WORKER_REPO) ---
    GITHUB_REPO="${CLAUDE_WORKER_REPO:-}"
    if [ -n "$GITHUB_REPO" ]; then
        _upgrade_from_github "$GITHUB_REPO"
        return
    fi

    # --- No source configured ---
    echo -e "${YELLOW}Usage:${NC}"
    echo -e "  claude-worker upgrade /path/to/claude-worker-X.Y.Z.tar.gz"
    echo ""
    echo -e "${YELLOW}To enable auto-upgrade, set one of:${NC}"
    echo -e "  CLAUDE_WORKER_URL   OBS/HTTP base URL (in .env or environment)"
    echo -e "  CLAUDE_WORKER_REPO  GitHub repo (e.g. your-org/repo)"
    return 1
}

_upgrade_from_obs() {
    local BASE_URL="$1"
    echo -e "${CYAN}Checking latest version from $BASE_URL ...${NC}"

    LATEST_JSON=$(curl -s --max-time 15 "$BASE_URL/latest.json" 2>/dev/null || echo "")
    if [ -z "$LATEST_JSON" ]; then
        echo -e "${RED}Could not fetch $BASE_URL/latest.json${NC}"
        return 1
    fi

    LATEST_VERSION=$(echo "$LATEST_JSON" | grep '"version"' | head -1 | sed 's/.*"\([^"]*\)".*/\1/')
    if [ -z "$LATEST_VERSION" ]; then
        echo -e "${RED}Could not parse version from latest.json${NC}"
        return 1
    fi

    if [ "$LATEST_VERSION" = "$CURRENT_VERSION" ]; then
        echo -e "${GREEN}Already up to date (v${CURRENT_VERSION}).${NC}"
        return 0
    fi

    echo -e "${CYAN}New version available: $CURRENT_VERSION -> $LATEST_VERSION${NC}"

    # Determine OS
    case "$(uname -s)" in
        Linux*)  OS_TAG="linux";;
        Darwin*) OS_TAG="macos";;
        *)       OS_TAG="linux";;
    esac

    # Extract file path from latest.json
    FILE_PATH=$(echo "$LATEST_JSON" | grep "\"$OS_TAG\"" | head -1 | sed 's/.*"\([^"]*\)".*/\1/')
    if [ -z "$FILE_PATH" ]; then
        echo -e "${RED}No $OS_TAG release found in latest.json${NC}"
        return 1
    fi

    DOWNLOAD_URL="$BASE_URL/$FILE_PATH"
    echo -e "${CYAN}Downloading: $DOWNLOAD_URL${NC}"

    TMPDIR=$(mktemp -d)
    local ARCHIVE_FILE="$TMPDIR/$(basename "$FILE_PATH")"
    curl -L --max-time 120 -o "$ARCHIVE_FILE" "$DOWNLOAD_URL"

    # Pass through CLAUDE_WORKER_URL so install.sh can preserve it
    export CLAUDE_WORKER_URL="$BASE_URL"

    _upgrade_from_archive "$ARCHIVE_FILE"
    rm -rf "$TMPDIR"
}

_upgrade_from_github() {
    local GITHUB_REPO="$1"
    echo -e "${CYAN}Checking GitHub Releases ($GITHUB_REPO)...${NC}"

    AUTH_HEADER=""
    if [ -n "$GITHUB_TOKEN" ]; then
        AUTH_HEADER="Authorization: token $GITHUB_TOKEN"
    fi

    LATEST_JSON=$(curl -s ${AUTH_HEADER:+-H "$AUTH_HEADER"} \
        "https://api.github.com/repos/$GITHUB_REPO/releases/latest" 2>/dev/null || echo "")

    if [ -z "$LATEST_JSON" ] || echo "$LATEST_JSON" | grep -q '"message"'; then
        echo -e "${RED}Could not fetch releases from GitHub.${NC}"
        echo -e "${YELLOW}For private repos, set GITHUB_TOKEN environment variable.${NC}"
        echo -e "${YELLOW}Or use manual upgrade: claude-worker upgrade /path/to/archive.tar.gz${NC}"
        return 1
    fi

    LATEST_TAG=$(echo "$LATEST_JSON" | grep '"tag_name"' | head -1 | sed 's/.*"\(.*\)".*/\1/')
    LATEST_VERSION=$(echo "$LATEST_TAG" | sed 's/^worker-v\?\|^v//')

    if [ "$LATEST_VERSION" = "$CURRENT_VERSION" ]; then
        echo -e "${GREEN}Already up to date (v${CURRENT_VERSION}).${NC}"
        return 0
    fi

    echo -e "${CYAN}New version available: $CURRENT_VERSION -> $LATEST_VERSION${NC}"

    case "$(uname -s)" in
        Linux*)  OS_TAG="linux";;
        Darwin*) OS_TAG="macos";;
        *)       OS_TAG="linux";;
    esac

    DOWNLOAD_URL=$(echo "$LATEST_JSON" | grep "browser_download_url.*${OS_TAG}" | head -1 | sed 's/.*"\(https:[^"]*\)".*/\1/')
    if [ -z "$DOWNLOAD_URL" ]; then
        echo -e "${RED}No release artifact found for $OS_TAG${NC}"
        return 1
    fi

    TMPDIR=$(mktemp -d)
    echo -e "${CYAN}Downloading...${NC}"
    curl -L ${AUTH_HEADER:+-H "$AUTH_HEADER"} -o "$TMPDIR/release.tar.gz" "$DOWNLOAD_URL"

    _upgrade_from_archive "$TMPDIR/release.tar.gz"
    rm -rf "$TMPDIR"
}

_upgrade_from_archive() {
    local ARCHIVE="$1"
    local TMPDIR=$(mktemp -d)

    echo -e "${CYAN}Extracting...${NC}"

    # Extract
    if [[ "$ARCHIVE" == *.zip ]]; then
        unzip -q "$ARCHIVE" -d "$TMPDIR"
    else
        tar xzf "$ARCHIVE" -C "$TMPDIR"
    fi

    # Find the install script inside the extracted directory
    EXTRACTED=$(find "$TMPDIR" -name "install.sh" -maxdepth 2 | head -1)
    if [ -z "$EXTRACTED" ]; then
        echo -e "${RED}No install.sh found in archive${NC}"
        rm -rf "$TMPDIR"
        return 1
    fi

    EXTRACTED_DIR=$(dirname "$EXTRACTED")
    chmod +x "$EXTRACTED_DIR/install.sh"
    bash "$EXTRACTED_DIR/install.sh" --upgrade

    rm -rf "$TMPDIR"

    # Restart if it was running
    NEW_VERSION=$(cat "$INSTALL_DIR/VERSION" 2>/dev/null || echo "unknown")
    echo -e "${GREEN}Upgraded to v${NEW_VERSION}!${NC}"
}

cmd_help() {
    echo "claude-worker v${VERSION} -- Claude Agent Worker CLI"
    echo ""
    echo "Usage: claude-worker <command> [options]"
    echo ""
    echo "Commands:"
    echo "  start              Start the worker service"
    echo "  stop               Stop the worker service"
    echo "  status             Show worker status and health"
    echo "  version            Show installed version"
    echo "  logs               Tail worker log output"
    echo "  upgrade [archive]  Upgrade from OBS/GitHub or local .tar.gz/.zip"
    echo "  help               Show this help message"
    echo ""
    echo "Environment:"
    echo "  CLAUDE_WORKER_HOME    Install directory (default: ~/.claude-worker)"
    echo "  CLAUDE_WORKER_URL     OBS/HTTP base URL for auto-upgrade (preferred)"
    echo "  CLAUDE_WORKER_REPO    GitHub repo for auto-upgrade (fallback)"
    echo "  GITHUB_TOKEN          Token for private GitHub repos"
    echo ""
    echo "Config: $INSTALL_DIR/.env"
}

# Dispatch
case "${1:-help}" in
    start)   cmd_start;;
    stop)    cmd_stop;;
    status)  cmd_status;;
    version|-v|--version) cmd_version;;
    logs)    cmd_logs;;
    upgrade) shift; cmd_upgrade "$@";;
    help|--help|-h) cmd_help;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        cmd_help
        exit 1;;
esac
