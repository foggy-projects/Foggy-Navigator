# Claude Agent Worker 配置示例
# 复制为 .env 后修改

# Worker 基础配置
AGENT_WORKER_PORT=3031
AGENT_WORKER_HOST=0.0.0.0
AGENT_WORKER_WORKER_NAME=我的开发机
AGENT_WORKER_WORKER_TOKEN=your-secret-token-here

# 允许操作的目录（JSON 数组格式，留空则不限制）
# Windows 示例:
# AGENT_WORKER_ALLOWED_CWDS=["D:\\projects","E:\\work"]
# Linux/Mac 示例:
# AGENT_WORKER_ALLOWED_CWDS=["/home/user/projects","/opt/work"]
AGENT_WORKER_ALLOWED_CWDS=["D:\\","C:\\Users\\oldse"]

# 最大并发任务数（同时运行多个会话）
AGENT_WORKER_MAX_CONCURRENT_TASKS=5

# LLM 配置（三选一，和你平时启动 claude 的方式保持一致）
#
# 模式1: 订阅模式 - 不设置以下项，使用 claude login 的订阅
#
# 模式2: AUTH_TOKEN + 自定义端点（你平时用 $env:ANTHROPIC_AUTH_TOKEN + $env:ANTHROPIC_BASE_URL 的场景）
# AGENT_WORKER_ANTHROPIC_AUTH_TOKEN=sk-xxx
# AGENT_WORKER_ANTHROPIC_BASE_URL=https://your-proxy.com/v1
#
# 模式3: API Key 模式（console.anthropic.com 的 API Key，按 token 计费）
# AGENT_WORKER_ANTHROPIC_API_KEY=sk-ant-api03-xxx
# AGENT_WORKER_ANTHROPIC_BASE_URL=https://your-proxy.com/v1

# 自动升级 URL（远程安装时自动写入，也可手动配置）
# claude-worker upgrade 会从此 URL 的 latest.json 检测新版本并下载
# CLAUDE_WORKER_URL=https://your-bucket.obs.cn-east-3.myhuaweicloud.com/claude-worker

# ---- 发版配置（仅开发者打包上传时使用，目标机器不需要）----
# 华为云 OBS Bucket 路径（obsutil 格式，用于 upload.ps1/upload.sh）
# RELEASE_OBS_BUCKET=obs://your-bucket/claude-worker
# 对应的公网 HTTP 下载地址（目标机器用此 URL 下载）
# RELEASE_BASE_URL=https://your-bucket.obs.cn-east-3.myhuaweicloud.com/claude-worker
# obsutil 安装: https://support.huaweicloud.com/utiltg-obs/obs_11_0003.html
# obsutil 配置: obsutil config -i=AK -k=SK -e=obs.cn-east-3.myhuaweicloud.com
