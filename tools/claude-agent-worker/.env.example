# Claude Agent Worker - Configuration
# Copy this file to .env and edit as needed.

# Worker basic settings
AGENT_WORKER_PORT=3031
AGENT_WORKER_HOST=0.0.0.0
AGENT_WORKER_WORKER_NAME=my-dev-machine
AGENT_WORKER_WORKER_TOKEN=your-secret-token-here

# Allowed working directories (JSON array, empty = no restriction)
# Windows example:
# AGENT_WORKER_ALLOWED_CWDS=["D:\\projects","E:\\work"]
# Linux/Mac example:
# AGENT_WORKER_ALLOWED_CWDS=["/home/user/projects","/opt/work"]
AGENT_WORKER_ALLOWED_CWDS=[]

# Max concurrent tasks
AGENT_WORKER_MAX_CONCURRENT_TASKS=5

# LLM config (pick one mode)
#
# Mode 1: Subscription - leave the following unset, use `claude login`
#
# Mode 2: AUTH_TOKEN + custom endpoint
# AGENT_WORKER_ANTHROPIC_AUTH_TOKEN=sk-xxx
# AGENT_WORKER_ANTHROPIC_BASE_URL=https://your-proxy.com/v1
#
# Mode 3: API Key (console.anthropic.com, pay per token)
# AGENT_WORKER_ANTHROPIC_API_KEY=sk-ant-api03-xxx
# AGENT_WORKER_ANTHROPIC_BASE_URL=https://your-proxy.com/v1

# Auto-upgrade URL (set automatically by remote installer, or manually)
# `claude-worker upgrade` checks latest.json at this URL for new versions
# CLAUDE_WORKER_URL=https://your-bucket.obs.cn-east-3.myhuaweicloud.com/claude-worker

# ---- Release config (developer only, not needed on target machines) ----
# OBS bucket path for obsutil upload
# RELEASE_OBS_BUCKET=obs://your-bucket/claude-worker
# Public HTTP download URL
# RELEASE_BASE_URL=https://your-bucket.obs.cn-east-3.myhuaweicloud.com/claude-worker
# obsutil install: https://support.huaweicloud.com/utiltg-obs/obs_11_0003.html
# obsutil config:  obsutil config -i=AK -k=SK -e=obs.cn-east-3.myhuaweicloud.com
